{
  // Editor settings for YAML files (formatting is handled by oxfmt via the
  // lefthook pre-commit hook; see .oxfmtrc.json — no editor formatter is bound).
  "[yaml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.wordWrap": "on",
    "editor.rulers": [200]
  },
  "[yml]": {
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "editor.wordWrap": "on",
    "editor.rulers": [200]
  },

  // YAML language server validation (schema-only; no .yamllint linting)
  "yaml.validate": true,
  "redhat.telemetry.enabled": false,
  "yaml.maxItemsComputed": 10000,

  // File associations
  "files.associations": {
    "*.yml": "yaml",
    "*.yaml": "yaml"
  },

  // Exclude large directories from watch
  "files.watcherExclude": {
    "**/logs/**": true,
    "**/overlays/4k-Movies Original Posters/**": true,
    "**/overlays/4k-TV Shows Original Posters/**": true
  }
}
